# --- Database ---
# Path to the SQLite database file. Created automatically on first run.
DB_PATH=./data/currency_exchange.db

# --- API ---
FRANKFURTER_BASE_URL=https://api.frankfurter.dev/v2
BASE_CURRENCY=USD
TARGET_CURRENCIES=UZS,RUB,EUR,GBP

# --- Backfill ---
# How many days of history to pull on first run / backfill.
BACKFILL_DAYS=730

# --- Scheduling ---
# Pipeline runs daily at this UTC hour:minute.
# 03:00 UTC = 08:00 UTC+5 (Tashkent)
SCHEDULE_UTC_HOUR=3
SCHEDULE_UTC_MINUTE=0

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=./logs/pipeline.log
